12. Simple Rule-Based Chatbot
app.py
Python
from flask import Flask
from flask import render_template
from flask import request
from flask import jsonify
import sqlite3

app = Flask(__name__)

@app.route('/')
def home():
    return render_template("index.html")

@app.route('/chat', methods=['POST'])
def chat():

    data = request.json

    message = data['message'].lower()

    response = "Sorry, I didn't understand."

    if "hello" in message:
        response = "Hello! How can I help you?"

    elif "name" in message:
        response = "I am an AI Chatbot."

    elif "course" in message:
        response = "We provide Cloud Computing courses."

    elif "contact" in message:
        response = "Contact us at support@example.com"

    conn = sqlite3.connect("database.db")
    cursor = conn.cursor()

    cursor.execute("""
    INSERT INTO chats
    (user_message, bot_response)
    VALUES (?,?)
    """,(message,response))

    conn.commit()
    conn.close()

    return jsonify({
        "response":response
    })

if __name__ == "__main__":
    app.run(debug=True)
13. AI-Based Chatbot Using GPT-2
Replace the chat function with:
Python
from transformers import pipeline

chatbot = pipeline(
"text-generation",
model="gpt2"
)

@app.route('/chat', methods=['POST'])
def chat():

    message = request.json['message']

    result = chatbot(
    message,
    max_length=50,
    num_return_sequences=1
    )

    response = result[0]['generated_text']

    return jsonify({
        "response":response
    })
